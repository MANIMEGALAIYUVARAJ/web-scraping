# Force HTTP → HTTPS
http://scrapper.cubegtp.com {
    redir https://{host}{uri} permanent
}

# Main HTTPS site
scrapper.cubegtp.com {
    tls sobiyasivakumar79@gmail.com

    encode gzip

    header {
        X-Frame-Options SAMEORIGIN
        X-Content-Type-Options nosniff
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # === 1. API routes → Flask backend ===
    handle /auth/* {
        reverse_proxy backend:61631
    }

    handle /api/* {
        reverse_proxy backend:61631
    }

    handle /webscraping/* {
        reverse_proxy backend:61631
    }

    # === 2. Everything else → React frontend (SPA fallback) ===
    handle {
        reverse_proxy frontend:80
    }

    # Cache static assets aggressively
    @static {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff* *.ttf *.eot *.json *.webmanifest
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
}
